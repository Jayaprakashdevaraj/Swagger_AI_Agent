    {
      "name": "09 Hardening (Phase 12)",
      "item": [
        {
          "name": "POST /api/execution/retry-failed (validation error)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 400', function(){ pm.response.to.have.status(400); });",
                "const json = pm.response.json();",
                "pm.test('validation error shape', function(){ pm.expect(json.success).to.eql(false); pm.expect(json.error.code).to.eql('VALIDATION_ERROR'); });"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": { "raw": "{{baseUrl}}/api/execution/retry-failed", "host": ["{{baseUrl}}"], "path": ["api", "execution", "retry-failed"] }
          }
        },
        {
          "name": "GET /api/spec/validate (method not allowed)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 405', function(){ pm.response.to.have.status(405); });",
                "const json = pm.response.json();",
                "pm.test('method not allowed shape', function(){ pm.expect(json.success).to.eql(false); pm.expect(json.error.code).to.eql('METHOD_NOT_ALLOWED'); });"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/spec/validate", "host": ["{{baseUrl}}"], "path": ["api", "spec", "validate"] }
          }
        },
        {
          "name": "GET /api/health (rate limit probe)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200 or 429', function(){ pm.expect([200, 429]).to.include(pm.response.code); });",
                "const baseUrl = pm.collectionVariables.get('baseUrl') || pm.environment.get('baseUrl');",
                "const total = 28;",
                "let completed = 0;",
                "let has429 = pm.response.code === 429;",
                "for (let i = 0; i < total; i += 1) {",
                "  pm.sendRequest({ url: `${baseUrl}/api/health`, method: 'GET' }, function (_err, resp) {",
                "    if (resp && resp.code === 429) { has429 = true; }",
                "    completed += 1;",
                "    if (completed === total) {",
                "      pm.test('rate limiting eventually returns 429', function(){ pm.expect(has429).to.eql(true); });",
                "    }",
                "  });",
                "}"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
          }
        }
      ]
    }
