      "name": "07 MCP Swagger Tools (Phase 10)",
      "item": [
        {
          "name": "POST /api/mcp/swagger/list-operations",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200', function(){ pm.response.to.have.status(200); });",
                "const json = pm.response.json();",
                "pm.test('operation list response shape', function(){ pm.expect(Array.isArray(json.operations)).to.eql(true); pm.expect(json.operationCount).to.be.a('number'); });",
                "if (Array.isArray(json.operations) && json.operations.length > 0) { pm.collectionVariables.set('operationId', json.operations[0].operationId); pm.collectionVariables.set('singleOperationId', json.operations[0].operationId); }"
              ]
