    {
      "name": "08 Retry & Aggregates (Phase 11)",
      "item": [
        {
          "name": "POST /api/execution/retry-failed",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200', function(){ pm.response.to.have.status(200); });",
                "const json = pm.response.json();",
                "pm.test('retry response shape', function(){ pm.expect(json.retryRunId).to.be.a('string'); pm.expect(json.retriedTestCount).to.be.a('number'); pm.expect(json.summary).to.be.an('object'); });",
                "pm.collectionVariables.set('retryRunId', json.retryRunId);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"runId\": \"{{runId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/execution/retry-failed", "host": ["{{baseUrl}}"], "path": ["api", "execution", "retry-failed"] }
          }
        },
        {
          "name": "GET /api/execution/status/:retryRunId",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200', function(){ pm.response.to.have.status(200); });",
                "const json = pm.response.json();",
                "pm.test('aggregates exist', function(){ pm.expect(json.report).to.be.an('object'); pm.expect(json.report.aggregates).to.be.an('object'); pm.expect(json.report.aggregates.byTag).to.be.an('object'); pm.expect(json.report.aggregates.byMethod).to.be.an('object'); pm.expect(json.report.aggregates.byPath).to.be.an('object'); });"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/execution/status/{{retryRunId}}", "host": ["{{baseUrl}}"], "path": ["api", "execution", "status", "{{retryRunId}}"] }
          }
        }
      ]
