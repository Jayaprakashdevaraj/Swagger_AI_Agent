{
  "info": {
    "name": "Swagger AI Agent - Phase 1 to 4",
    "description": "Postman collection to validate health + spec ingestion and introspection APIs up to Phase 4.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Phase 1 - Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Phase 4 - Spec APIs",
      "item": [
        {
          "name": "POST /api/spec/import (file)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.expect(json.specId).to.exist;",
                  "pm.collectionVariables.set('specId', json.specId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": {\n    \"type\": \"file\",\n    \"path\": \"{{sampleSpecPath}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/spec/import",
              "host": ["{{baseUrl}}"],
              "path": ["api", "spec", "import"]
            }
          }
        },
        {
          "name": "POST /api/spec/validate (specId)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specId\": \"{{specId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/spec/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "spec", "validate"]
            }
          }
        },
        {
          "name": "POST /api/spec/validate (rawContent)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rawContent\": \"{\\\"openapi\\\":\\\"3.0.3\\\",\\\"info\\\":{\\\"title\\\":\\\"Inline API\\\",\\\"version\\\":\\\"1.0.0\\\"},\\\"paths\\\":{\\\"/ping\\\":{\\\"get\\\":{\\\"responses\\\":{\\\"200\\\":{\\\"description\\\":\\\"OK\\\"}}}}}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/spec/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "spec", "validate"]
            }
          }
        },
        {
          "name": "GET /api/spec/:specId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/spec/{{specId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "spec", "{{specId}}"]
            }
          }
        },
        {
          "name": "GET /api/spec/:specId/operations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/spec/{{specId}}/operations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "spec", "{{specId}}", "operations"]
            }
          }
        },
        {
          "name": "GET /api/spec/:specId/tags",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/spec/{{specId}}/tags",
              "host": ["{{baseUrl}}"],
              "path": ["api", "spec", "{{specId}}", "tags"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "specId",
      "value": ""
    },
    {
      "key": "sampleSpecPath",
      "value": "C:/Users/JAYAPRAKASH/Downloads/Swagger/Swagger AI Agent/swagger-ai-agent/samples/sample-openapi.json"
    }
  ]
}
