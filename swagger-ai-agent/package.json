{
  "name": "swagger-ai-agent",
  "version": "1.0.0",
  "description": "Enterprise-grade Swagger AI Agent — API-first, Node.js + TypeScript + Express",
  "main": "dist/src/core/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/core/server.ts",
    "build": "tsc",
    "start": "node dist/src/core/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "axios": "^1.8.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "winston": "^3.13.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "keywords": ["swagger", "openapi", "ai-agent", "mcp", "api-testing"],
  "author": "",
  "license": "MIT"
}
